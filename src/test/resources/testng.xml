<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2"
       name="SauceDemo suite"
       parallel="tests">

    <listeners>
        <listener class-name="listners.TestListener"/>
    </listeners>

    <test name="Thread 1">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest">
                <methods>
                    <include name="chekLoginWithNegativeCred1"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Thread 2">
        <classes>
            <class name="tests.CartTest"/>
            <class name="tests.LocatorsTest"/>
        </classes>
    </test>
</suite>
